{
    "name": "eslam/model-search",
    "description": "A dynamic model search system for Laravel",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "search",
        "eloquent",
        "dynamic"
    ],
    "require": {
        "php": "^8.1",
        "laravel/framework": "^9.0|^10.0|^11.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0|^10.0|^11.0",
        "orchestra/testbench": "^7.0|^8.0|^9.0"
    },
    "autoload": {
        "psr-4": {
            "Eslam\\ModelSearch\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Eslam\\ModelSearch\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Eslam\\ModelSearch\\Providers\\ModelSearchServiceProvider"
            ],
            "facades": {
                "ModelSearch": "Eslam\\ModelSearch\\Facades\\ModelSearch"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}